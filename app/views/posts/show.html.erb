<div id="centered">
	<h1><%= sanitize @post.title_as_html %></h1>
	<p><i><%= @post.date %></i></p>
	<% if Current.user %>
		<%= link_to "Edit", edit_post_path(@post) %>
		<%= link_to "Destroy", post_path(@post), data: {
		  turbo_method: :delete,
		  turbo_confirm: "Are you sure?"
	  	} %>
	<% end %>
</div>

<%= sanitize @post.body_as_html %>

