<h1><%= sanitize @post.title_as_html %></h1>

<i><%= @post.date %></i>

<%= sanitize @post.body_as_html %>

<ul>
  <li><%= link_to "Edit", edit_post_path(@post) %></li>
  <li><%= link_to "Destroy", post_path(@post), data: {
	  turbo_method: :delete,
	  turbo_confirm: "Are you sure?"
	} %></li>
</ul>